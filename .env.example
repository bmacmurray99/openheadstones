# ── Identity ─────────────────────────────────────────────
DISPLAY_NAME=Your Name
HEADLINE=Your Professional Title
BIO=A sentence or two about who you are and what you do.
LOCATION=City, Country

# ── Links ────────────────────────────────────────────────
WEBSITE=https://yoursite.com
LINKEDIN_URL=https://linkedin.com/in/you
GITHUB_URL=https://github.com/you
TWITTER_URL=https://x.com/you
BLUESKY_URL=https://bsky.app/profile/you.bsky.social
MASTODON_URL=
YOUTUBE_URL=
CALENDAR_URL=
AVATAR_URL=          # path from /public (e.g. /avatar.jpg) or any image URL

# ── Deployment ───────────────────────────────────────────
SITE_DOMAIN=https://yourname.com

# ── Blog ─────────────────────────────────────────────────
BLOG_ENABLED=false

# ── AI Chatbot ───────────────────────────────────────────
CHATBOT_ENABLED=false

# Webhook URL — receives { chatInput, sessionId } and optionally resumeContext as FormData.
CHATBOT_WEBHOOK_URL=

# Set to false if you run your own RAG pipeline and don't want resume.md
# injected into every request.
CHATBOT_SEND_RESUME_CONTEXT=true

# Gate — set to true to require visitors to enter name, email, and company before chatting.
CHATBOT_GATE=false
# Optional: POST destination for gate form submissions (e.g. a CRM webhook or n8n endpoint).
# Receives name, email, and company as multipart/form-data. Fire-and-forget — failures are silent.
CHATBOT_GATE_FORM_URL=
